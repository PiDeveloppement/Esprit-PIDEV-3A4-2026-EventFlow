<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="900" prefWidth="1600"
            style="-fx-background-color: #f1f5f9;"
            stylesheets="@../../css/design-system.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.sponsor.SponsorAdminController">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="0">

                <!-- ===== STATS (3 cards) ===== -->
                <HBox spacing="16" style="-fx-padding: 24 35; -fx-background-color: #f1f5f9;">

                    <!-- Card 1 : Total Sponsors -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-border-radius: 16; -fx-border-color: #e2e8f0;
                                 -fx-border-width: 1; -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="52" prefHeight="52"
                                       style="-fx-background-color: #ede9fe; -fx-background-radius: 14;">
                                <Label text="💼" style="-fx-font-size: 26px;"/>
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="totalSponsorsSectionLabel" text="Sponsors Total"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                                <Label fx:id="totalSponsorsLabel" text="0"
                                       style="-fx-text-fill: #7c3aed; -fx-font-size: 32px; -fx-font-weight: 900;"/>
                            </VBox>
                        </HBox>
                        <Pane prefHeight="6"
                              style="-fx-background-color: #7c3aed; -fx-background-radius: 4;">
                            <VBox.margin><Insets top="14"/></VBox.margin>
                        </Pane>
                        <Label text="✓ Actifs"
                               style="-fx-text-fill: #a855f7; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    </VBox>

                    <!-- Card 2 : Contribution Totale -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-border-radius: 16; -fx-border-color: #e2e8f0;
                                 -fx-border-width: 1; -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="52" prefHeight="52"
                                       style="-fx-background-color: #d1fae5; -fx-background-radius: 14;">
                                <Label text="💎" style="-fx-font-size: 26px;"/>
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="totalContributionSectionLabel" text="Contribution Totale"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                                <Label fx:id="totalContributionLabel" text="0,00 DT"
                                       style="-fx-text-fill: #15803d; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            </VBox>
                        </HBox>
                        <Pane prefHeight="6"
                              style="-fx-background-color: #10b981; -fx-background-radius: 4;">
                            <VBox.margin><Insets top="14"/></VBox.margin>
                        </Pane>
                        <Label text="💰 Engagée"
                               style="-fx-text-fill: #059669; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    </VBox>

                    <!-- Card 3 : Moyenne -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-border-radius: 16; -fx-border-color: #e2e8f0;
                                 -fx-border-width: 1; -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="52" prefHeight="52"
                                       style="-fx-background-color: #dbeafe; -fx-background-radius: 14;">
                                <Label text="📊" style="-fx-font-size: 26px;"/>
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="avgContributionSectionLabel" text="Moyenne/Sponsor"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                                <Label fx:id="avgContributionLabel" text="0,00 DT"
                                       style="-fx-text-fill: #1e40af; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            </VBox>
                        </HBox>
                        <Pane prefHeight="6"
                              style="-fx-background-color: #3b82f6; -fx-background-radius: 4;">
                            <VBox.margin><Insets top="14"/></VBox.margin>
                        </Pane>
                        <Label text="📈 Performance"
                               style="-fx-text-fill: #2563eb; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    </VBox>

                </HBox>

                <!-- ===== GRAPHIQUE CIRCULAIRE ===== -->
                <VBox style="-fx-padding: 0 35 20 35;">
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-border-radius: 16; -fx-border-color: #e2e8f0;
                                 -fx-border-width: 1; -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                        <Label text="Répartition des contributions"
                               style="-fx-font-size: 16px; -fx-font-weight: 800;
                                      -fx-text-fill: #0f172a; -fx-padding: 0 0 10 0;"/>
                        <PieChart fx:id="contributionsChart"
                                  labelsVisible="true" legendVisible="true"
                                  prefHeight="400" prefWidth="800"/>
                    </VBox>
                </VBox>

                <!-- ===== FILTRES + BOUTONS ===== -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 18 35; -fx-background-color: white;
                             -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <TextField fx:id="searchField" prefWidth="240"
                               promptText="🔍 Rechercher sponsor..."/>
                    <ComboBox fx:id="companyFilter" prefWidth="200"
                              promptText="🏢 Entreprise"/>
                    <ComboBox fx:id="eventFilter" prefWidth="200"
                              promptText="📅 Événement"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="exportExcelBtn" text="📥 Exporter Excel"
                            minHeight="42" minWidth="160"
                            style="-fx-background-color: #1d4ed8; -fx-text-fill: white;
                                   -fx-font-weight: 800; -fx-font-size: 13px;
                                   -fx-background-radius: 10; -fx-padding: 10 20;
                                   -fx-cursor: hand;"/>
                    <Button fx:id="addSponsorBtn" text="➕ Nouveau Sponsor"
                            minHeight="42" minWidth="180"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;
                                   -fx-font-weight: 800; -fx-font-size: 13px;
                                   -fx-background-radius: 10; -fx-padding: 10 22;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- ===== LISTE CARDS ===== -->
                <VBox spacing="20" style="-fx-padding: 28 35;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📋" style="-fx-font-size: 18px;"/>
                        <Label text="Sponsors Enregistrés"
                               style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="statusLabel" text="..."
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </HBox>
                    <ScrollPane fx:id="cardsScroll" fitToWidth="true"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <TilePane fx:id="cardsPane" hgap="16" prefColumns="3"
                                  style="-fx-padding: 10;" vgap="16"/>
                    </ScrollPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>