<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="0" style="-fx-background-color: white;              -fx-background-radius: 14;              -fx-border-radius: 14;              -fx-border-color: #e2e8f0;              -fx-border-width: 1;              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 3);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.sponsor.SponsorCardController">

    <!-- Barre accent gauche -->
    <Pane prefHeight="174.0" prefWidth="0.0" style="-fx-background-color: #1565C0;                  -fx-background-radius: 14 0 0 14;" />

    <!-- Contenu -->
    <HBox prefHeight="174.0" prefWidth="471.0" spacing="14" style="-fx-padding: 16;" HBox.hgrow="ALWAYS">

        <!-- Infos -->
        <VBox spacing="6" HBox.hgrow="ALWAYS">

            <!-- Nom + badge contribution -->
            <HBox alignment="CENTER_LEFT" spacing="8">
               <ImageView fx:id="logoView" fitHeight="50" fitWidth="50" preserveRatio="true" />
                <Label fx:id="companyLabel" maxWidth="220" prefHeight="21.0" prefWidth="156.0" style="-fx-font-size: 15px; -fx-font-weight: 900; -fx-text-fill: #0f172a;" text="               Entreprise" />
                <Region prefHeight="50.0" prefWidth="82.0" HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="4" style="-fx-background-color: #d1fae5;                              -fx-background-radius: 20;                              -fx-padding: 4 10;                              -fx-border-color: #a7f3d0;                              -fx-border-width: 1;                              -fx-border-radius: 20;">
                    <Label style="-fx-font-size: 11px;" text="💰" />
                    <Label fx:id="contributionLabel" style="-fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: #059669;" text="0,00 DT" />
                </HBox>
            </HBox>

            <!-- Email -->
            <HBox alignment="CENTER_LEFT" spacing="5">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;" />
                <Label fx:id="emailLabel" maxWidth="280" style="-fx-text-fill: #3b82f6; -fx-font-size: 12px; -fx-font-weight: 600;" text="email@company.tn" />
            </HBox>

            <!-- Événement -->
            <HBox alignment="CENTER_LEFT" spacing="5">
                <Label style="-fx-font-size: 11px;" />
                <Label fx:id="eventLabelPrefix" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 700;" text="Événement :" />
                <Label fx:id="eventLabel" style="-fx-text-fill: #334155; -fx-font-size: 12px;" text="—" />
            </HBox>

            <Separator opacity="0.4" />

            <!-- Boutons -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Button fx:id="detailsBtn" style="-fx-background-color: #1d4ed8; -fx-text-fill: white;                                -fx-font-weight: 800; -fx-font-size: 12px;                                -fx-background-radius: 8; -fx-padding: 6 12; -fx-cursor: hand;" text="Détails" />
                <Button fx:id="pdfBtn" style="-fx-background-color: #f97316; -fx-text-fill: white;                                -fx-font-weight: 800; -fx-font-size: 12px;                                -fx-background-radius: 8; -fx-padding: 6 12; -fx-cursor: hand;" text="📄 Contrat" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="editBtn" style="-fx-background-color: #eff6ff; -fx-text-fill: #1d4ed8;                                -fx-font-weight: 700; -fx-font-size: 12px;                                -fx-background-radius: 8; -fx-padding: 6 10; -fx-cursor: hand;                                -fx-border-color: #bfdbfe; -fx-border-width: 1; -fx-border-radius: 8;" text="Modifier" />
                <Button fx:id="deleteBtn" style="-fx-background-color: #fff1f2; -fx-text-fill: #be123c;                                -fx-font-weight: 700; -fx-font-size: 12px;                                -fx-background-radius: 8; -fx-padding: 6 10; -fx-cursor: hand;                                -fx-border-color: #fecdd3; -fx-border-width: 1; -fx-border-radius: 8;" text="Supprimer" />
            </HBox>
        </VBox>
    </HBox>
</HBox>
