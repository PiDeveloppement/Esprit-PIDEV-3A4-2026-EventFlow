<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.image.ImageView?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.resource.SalleController">

    <VBox spacing="0" style="-fx-background-color: #f1f5f9;">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <!-- ===== OUTER GRADIENT BORDER WRAPPER ===== -->
        <VBox style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);
                     -fx-background-radius: 16; -fx-padding: 2;">
            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 30;">

                <!-- ===== HEADER: Title + Stat Cards ===== -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox.margin><Insets bottom="25"/></VBox.margin>

                    <!-- Title block -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="🚪" style="-fx-font-size: 20;"/>
                            <Label text="Gestion des Salles"
                                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        </HBox>
                        <Label text="Consultez et gérez votre inventaire de salles"
                               style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <!-- Stat: Total (blue) -->
                    <VBox spacing="4" alignment="CENTER_LEFT" minWidth="130"
                          style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #1d4ed8);
                                 -fx-background-radius: 10; -fx-padding: 14 18;
                                 -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 8, 0, 0, 2);">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="🏢" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
                            <Label text="Total" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
                        </HBox>
                        <Label fx:id="totalSallesLabel" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>

                    <!-- Stat: Occupées (red) -->
                    <VBox spacing="4" alignment="CENTER_LEFT" minWidth="120"
                          style="-fx-background-color: linear-gradient(to bottom right, #ef4444, #dc2626);
                                 -fx-background-radius: 10; -fx-padding: 14 18;
                                 -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.35), 8, 0, 0, 2);">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="👥" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
                            <Label text="Occupées" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
                        </HBox>
                        <Label fx:id="sallesOccupeesLabel" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                </HBox>

                <!-- ===== SEARCH & FILTER BAR ===== -->
                <VBox spacing="14"
                      style="-fx-background-color: #f8fafc;
                             -fx-border-color: #e2e8f0; -fx-border-width: 1;
                             -fx-border-radius: 12; -fx-background-radius: 12;
                             -fx-padding: 18;">
                    <VBox.margin><Insets bottom="22"/></VBox.margin>

                    <!-- Bar title -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🔍" style="-fx-font-size: 14;"/>
                        <Label text="Recherche et Filtres"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    </HBox>

                    <!-- Filter controls row -->
                    <HBox spacing="14" alignment="BOTTOM_LEFT">

                        <!-- Name search -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Nom de la salle"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="searchNameField"
                                       promptText="Rechercher..."
                                       style="-fx-padding: 10 12; -fx-border-color: #e5e7eb;
                                              -fx-border-width: 2; -fx-border-radius: 8;
                                              -fx-background-radius: 8; -fx-font-size: 13;"/>
                        </VBox>

                        <!-- Building filter -->
                        <VBox spacing="6" prefWidth="155">
                            <Label text="Bloc / Bâtiment"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <ComboBox fx:id="filterBuildingCombo"
                                      maxWidth="Infinity"
                                      style="-fx-border-color: #e5e7eb; -fx-border-width: 2;
                                             -fx-border-radius: 8; -fx-background-radius: 8;
                                             -fx-font-size: 13; -fx-background-color: white;"/>
                        </VBox>

                        <!-- Status filter -->
                        <VBox spacing="6" prefWidth="140">
                            <Label text="État"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <ComboBox fx:id="filterStatusCombo"
                                      maxWidth="Infinity"
                                      style="-fx-border-color: #e5e7eb; -fx-border-width: 2;
                                             -fx-border-radius: 8; -fx-background-radius: 8;
                                             -fx-font-size: 13; -fx-background-color: white;"/>
                        </VBox>

                        <!-- Capacity range -->
                        <VBox spacing="6">
                            <Label text="Capacité Min / Max"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <HBox spacing="8">
                                <TextField fx:id="searchCapMinField" promptText="Min" prefWidth="68"
                                           style="-fx-padding: 10 8; -fx-border-color: #e5e7eb;
                                                  -fx-border-width: 2; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-font-size: 13;"/>
                                <TextField fx:id="searchCapMaxField" promptText="Max" prefWidth="68"
                                           style="-fx-padding: 10 8; -fx-border-color: #e5e7eb;
                                                  -fx-border-width: 2; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-font-size: 13;"/>
                            </HBox>
                        </VBox>

                        <!-- Buttons -->
                        <HBox spacing="10" alignment="BOTTOM_LEFT">
                            <Button text="↺  Réinitialiser" onAction="#resetFilters"
                                    style="-fx-background-color: #64748b; -fx-text-fill: white;
                                           -fx-padding: 10 16; -fx-background-radius: 8;
                                           -fx-font-size: 13; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Button text="＋  Ajouter" onAction="#ouvrirPopupAjout"
                                    style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2);
                                           -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-padding: 10 18; -fx-background-radius: 10;
                                           -fx-font-size: 13; -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.35), 10, 0, 0, 3);"/>
                            <Button text="📄  PDF" onAction="#exportPDF"
                                    style="-fx-background-color: white; -fx-border-color: #64748b;
                                           -fx-border-width: 1.5; -fx-border-radius: 8;
                                           -fx-text-fill: #64748b; -fx-font-weight: bold;
                                           -fx-padding: 10 16; -fx-background-radius: 8;
                                           -fx-font-size: 13; -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                </VBox>

                <!-- ===== BOTTOM CONTENT: Card Grid + Map ===== -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <!-- LEFT: Cards (FlowPane inside ScrollPane) -->
                    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                                prefHeight="520" minHeight="300"
                                style="-fx-background-color: transparent; -fx-background: transparent;
                                       -fx-border-color: transparent; -fx-padding: 0;">
                        <content>
                            <VBox spacing="0">
                                <!-- FlowPane filled by controller with SalleCard nodes -->
                                <FlowPane fx:id="sallesFlowPane"
                                          hgap="18" vgap="18"
                                          prefWrapLength="700"
                                          style="-fx-background-color: transparent; -fx-padding: 2 2 8 2;">
                                </FlowPane>

                                <!-- Empty state (shown/hidden by controller) -->
                                <VBox fx:id="emptyState"
                                      alignment="CENTER" spacing="8"
                                      style="-fx-border-color: #d1d5db; -fx-border-width: 2;
                                             -fx-border-style: dashed; -fx-border-radius: 12;
                                             -fx-background-radius: 12; -fx-background-color: white;
                                             -fx-padding: 60 20;"
                                      visible="false" managed="false">
                                    <Label text="📭" style="-fx-font-size: 44;"/>
                                    <Label text="Aucune salle trouvée"
                                           style="-fx-font-size: 17; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                                    <Label text="Essayez de modifier vos filtres de recherche."
                                           style="-fx-font-size: 13; -fx-text-fill: #9ca3af;"/>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- RIGHT: Map Panel -->
                    <VBox prefWidth="355" spacing="10" minWidth="320"
                          style="-fx-background-color: white;
                                 -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                 -fx-border-radius: 12; -fx-background-radius: 12;
                                 -fx-padding: 15;">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="📍" style="-fx-font-size: 14;"/>
                            <Label text="Localisation sur le Campus"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        </HBox>

                        <StackPane VBox.vgrow="ALWAYS"
                                   style="-fx-background-radius: 10; -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 10; -fx-border-width: 1;"
                                   minHeight="420">
                            <WebView fx:id="mapWebView"/>
                        </StackPane>
                    </VBox>
                </HBox>

            </VBox>
        </VBox>
    </VBox>
</ScrollPane>