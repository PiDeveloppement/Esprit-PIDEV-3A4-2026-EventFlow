<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<!-- Outer scroll + background #f1f5f9 -->
<ScrollPane fitToWidth="true"
            style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.resource.SalleFormController">

    <!-- Centered layout like the web page -->
    <VBox alignment="TOP_CENTER" style="-fx-background-color: #f1f5f9; -fx-padding: 40 0 40 0;">

        <!-- WHITE CARD (max-width 550px like web) -->
        <VBox maxWidth="550" minWidth="400"
              spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 25, 0, 0, 5);
                     -fx-padding: 35 35 35 35;">

            <!-- ===== HEADER ===== -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox.margin><Insets bottom="25"/></VBox.margin>

                <!-- Blue icon square -->
                <StackPane style="-fx-background-color: #3b82f6;
                                  -fx-background-radius: 12;
                                  -fx-padding: 12;"
                           minWidth="50" minHeight="50">
                    <Label text="🏠" style="-fx-font-size: 22; -fx-text-fill: white;"/>
                </StackPane>

                <!-- Title + subtitle -->
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="titleLabel"
                           text="Ajouter une Salle"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label fx:id="subtitleLabel"
                           text="Gestion des espaces de l'établissement"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                </VBox>

                <!-- Voice button -->
                <VBox alignment="CENTER" spacing="5">
                    <Button fx:id="voiceBtn"
                            onAction="#toggleVoiceControl"
                            text="🎙"
                            prefWidth="45" prefHeight="45"
                            style="-fx-background-color: #ef4444;
                                   -fx-background-radius: 50;
                                   -fx-text-fill: white;
                                   -fx-font-size: 16;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                        <tooltip><Tooltip text="Activer la commande vocale"/></tooltip>
                    </Button>
                    <Label fx:id="voiceStatusLabel"
                           text="Micro Off"
                           style="-fx-font-size: 9; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- SEPARATOR -->
            <Separator style="-fx-opacity: 0.5;">
                <VBox.margin><Insets bottom="22"/></VBox.margin>
            </Separator>

            <!-- ===== ALERT ZONE (validation errors) ===== -->
            <VBox fx:id="alertBox" spacing="0"
                  visible="false" managed="false">
                <VBox.margin><Insets bottom="15"/></VBox.margin>
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: linear-gradient(to right, #ef4444, #dc2626);
                             -fx-background-radius: 12;
                             -fx-padding: 14 18;
                             -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.3), 10, 0, 0, 3);">
                    <Label text="⚠" style="-fx-font-size: 16; -fx-text-fill: white;"/>
                    <VBox spacing="3">
                        <Label text="Erreurs de validation :"
                               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label fx:id="alertMessageLabel"
                               text=""
                               style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"
                               wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ===== FORM FIELDS ===== -->
            <VBox spacing="18">

                <!-- Nom de la salle + Auto -->
                <VBox spacing="6">
                    <Label text="Nom de la salle"
                           style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <HBox spacing="10">
                        <TextField fx:id="nameField"
                                   promptText="Ex: Salle de conférence"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 45;
                                          -fx-background-radius: 8;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 8;
                                          -fx-padding: 0 12;
                                          -fx-font-size: 13;"/>
                        <Button text="🔍 Auto"
                                onAction="#rechercherImageAutomatique"
                                style="-fx-background-color: #3b82f6;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 8;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 13;
                                       -fx-padding: 0 15;
                                       -fx-cursor: hand;
                                       -fx-pref-height: 45;"/>
                    </HBox>
                </VBox>

                <!-- Capacité + Étage (side by side) -->
                <HBox spacing="15">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Capacité"
                               style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        <TextField fx:id="capacityField"
                                   promptText="Ex: 30"
                                   maxWidth="Infinity"
                                   style="-fx-pref-height: 45;
                                          -fx-background-radius: 8;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 8;
                                          -fx-padding: 0 12;
                                          -fx-font-size: 13;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Étage"
                               style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        <TextField fx:id="floorField"
                                   promptText="Ex: 1"
                                   maxWidth="Infinity"
                                   style="-fx-pref-height: 45;
                                          -fx-background-radius: 8;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 8;
                                          -fx-padding: 0 12;
                                          -fx-font-size: 13;"/>
                    </VBox>
                </HBox>

                <!-- Bâtiment / Bloc -->
                <VBox spacing="6">
                    <Label text="Bâtiment / Bloc"
                           style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <TextField fx:id="buildingField"
                               promptText="Ex: Bloc G"
                               maxWidth="Infinity"
                               style="-fx-pref-height: 45;
                                      -fx-background-radius: 8;
                                      -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 8;
                                      -fx-padding: 0 12;
                                      -fx-font-size: 13;"/>
                </VBox>

                <!-- Statut -->
                <VBox spacing="6">
                    <Label text="Statut actuel"
                           style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <ComboBox fx:id="statusCombo"
                              promptText="Choisir un statut"
                              maxWidth="Infinity"
                              style="-fx-pref-height: 45;
                                     -fx-background-radius: 8;
                                     -fx-border-color: #e2e8f0;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 13;
                                     -fx-background-color: white;"/>
                </VBox>

                <!-- Image Section (dashed box like web) -->
                <VBox spacing="10"
                      style="-fx-background-color: #f8fafc;
                             -fx-padding: 15;
                             -fx-background-radius: 12;
                             -fx-border-color: #cbd5e1;
                             -fx-border-style: dashed;
                             -fx-border-radius: 12;
                             -fx-border-width: 1.5;">

                    <Label text="Photo de la salle"
                           style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13;"/>

                    <HBox alignment="CENTER_LEFT" spacing="15">

                        <!-- Manual pick button -->
                        <Button text="🖼️ Manuel"
                                onAction="#choisirImage"
                                style="-fx-background-color: #64748b;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-padding: 9 16;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;"/>

                        <!-- Image path label (file name) -->
                        <Label fx:id="imageNameLabel"
                               text="Aucune image sélectionnée"
                               HBox.hgrow="ALWAYS"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"
                               ellipsisString="..."
                               maxWidth="Infinity"/>

                        <!-- Preview thumbnail (white card like web) -->
                        <StackPane style="-fx-background-color: white;
                                          -fx-padding: 5;
                                          -fx-background-radius: 10;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 5, 0, 0, 2);">
                            <ImageView fx:id="previewImage"
                                       fitWidth="70" fitHeight="70"
                                       preserveRatio="true"/>
                        </StackPane>
                    </HBox>
                </VBox>

            </VBox>

            <!-- ===== ACTION BUTTONS ===== -->
            <HBox alignment="CENTER" spacing="20">
                <VBox.margin><Insets top="30"/></VBox.margin>

                <!-- Cancel -->
                <Button text="✖  Annuler"
                        onAction="#annuler"
                        prefWidth="150" prefHeight="45"
                        style="-fx-background-color: #f1f5f9;
                               -fx-text-fill: #64748b;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <!-- Save -->
                <Button text="💾  Enregistrer"
                        onAction="#enregistrer"
                        prefWidth="180" prefHeight="45"
                        style="-fx-background-color: #22c55e;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(34,197,94,0.35), 12, 0, 0, 4);"/>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>
