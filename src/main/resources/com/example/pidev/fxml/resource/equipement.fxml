<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    Design fidèle au screenshot Symfony :
    - Fond blanc pur, bordure bleue fine en haut de la fenêtre
    - Carte blanche avec bordure bleue-violette à gauche (style border-left)
    - Header : icône chip violet, titre bold, stats Total (bleu) + Alertes (rouge)
    - Section Recherche et Filtres grise avec champs alignés
    - Grille de cartes équipement avec image, badges statut, infos, actions
-->

<VBox spacing="0"
      style="-fx-background-color: #ffffff;"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.resource.EquipementController">

    <!-- Barre bleue du haut (comme le header EventFlow) -->
    <HBox style="-fx-background-color: #2563eb; -fx-min-height: 4; -fx-max-height: 4;"/>

    <VBox spacing="0" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="30" left="30" right="30" top="20"/></padding>

        <!-- ═══════════════════════════════════════
             CARTE PRINCIPALE (bordure bleue-violette)
        ════════════════════════════════════════ -->
        <VBox spacing="0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-border-color: #6366f1; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 2);">

            <VBox spacing="20" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>

                <!-- ─── HEADER : titre + stats ─── -->
                <HBox alignment="CENTER_LEFT" spacing="15">

                    <!-- Icône chip violet -->
                    <StackPane style="-fx-background-color: #ede9fe; -fx-background-radius: 10; -fx-min-width: 46; -fx-min-height: 46; -fx-max-width: 46; -fx-max-height: 46;">
                        <Label text="⚡" style="-fx-font-size: 20; -fx-text-fill: #6d28d9;"/>
                    </StackPane>

                    <!-- Titre -->
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Inventaire des Équipements"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="Gérez votre inventaire EventFlow"
                               style="-fx-font-size: 13; -fx-text-fill: #6b7280;"/>
                    </VBox>

                    <!-- Stat Total (bleu) -->
                    <VBox alignment="CENTER" spacing="2"
                          style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-padding: 14 30; -fx-min-width: 130;">
                        <HBox alignment="CENTER" spacing="6">
                            <Label text="👥" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            <Label text="Total" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                        </HBox>
                        <Label fx:id="totalArticlesLabel" text="0"
                               style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>

                    <!-- Stat Alertes (rouge) -->
                    <VBox alignment="CENTER" spacing="2"
                          style="-fx-background-color: #dc2626; -fx-background-radius: 10; -fx-padding: 14 30; -fx-min-width: 130;">
                        <HBox alignment="CENTER" spacing="6">
                            <Label text="⚠" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                            <Label text="Alertes" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.85);"/>
                        </HBox>
                        <Label fx:id="aReparerLabel" text="0"
                               style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                </HBox>

                <!-- ─── SECTION RECHERCHE ET FILTRES ─── -->
                <VBox spacing="12"
                      style="-fx-background-color: #f9fafb; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 18;">

                    <!-- Titre section -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔍" style="-fx-font-size: 13; -fx-text-fill: #6366f1;"/>
                        <Label text="Recherche et Filtres"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    </HBox>

                    <!-- Champs filtre en ligne -->
                    <HBox spacing="15" alignment="BOTTOM_LEFT">

                        <!-- Nom équipement -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Nom de l'équipement"
                                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="searchField" promptText="Rechercher..."
                                       style="-fx-background-color: white; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 1; -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13; -fx-text-fill: #374151;"/>
                        </VBox>

                        <!-- Catégorie -->
                        <VBox spacing="6" prefWidth="220">
                            <Label text="Catégorie"
                                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <ComboBox fx:id="categoryFilter" maxWidth="Infinity" promptText="Toutes catégories"
                                      style="-fx-background-color: white; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 1; -fx-border-radius: 6; -fx-font-size: 13;"/>
                        </VBox>

                        <!-- Bouton Réinitialiser -->
                        <VBox spacing="6">
                            <Label text=" " style="-fx-font-size: 12;"/>
                            <Button text="↺  Réinitialiser" prefHeight="38" prefWidth="130"
                                    style="-fx-background-color: #6b7280; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        </VBox>

                        <!-- Bouton Ajouter (violet) -->
                        <VBox spacing="6">
                            <Label text=" " style="-fx-font-size: 12;"/>
                            <Button onAction="#ouvrirAjout" text="＋  Ajouter" prefHeight="38" prefWidth="120"
                                    style="-fx-background-color: #6366f1; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ─── TABLE ─── -->
                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 6, 0, 0, 2);">

                    <TableView fx:id="equipementTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-border-color: transparent;">
                        <columns>
                            <TableColumn fx:id="imageCol"    text="Aperçu"      prefWidth="85"/>
                            <TableColumn fx:id="nameCol"     text="Désignation" prefWidth="230"/>
                            <TableColumn fx:id="typeCol"     text="Catégorie"   prefWidth="150"/>
                            <TableColumn fx:id="quantityCol" text="Stock"       prefWidth="90"/>
                            <TableColumn fx:id="statusCol"   text="État"        prefWidth="150"/>
                            <TableColumn fx:id="actionCol"   text="Actions"     prefWidth="160"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </VBox>
        </VBox>
    </VBox>
</VBox>
