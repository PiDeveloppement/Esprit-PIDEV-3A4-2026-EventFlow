<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1600" style="-fx-background-color: #f1f5f9;" stylesheets="@../../css/design-system.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.depense.DepenseListController">

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">

            <VBox fillWidth="true" spacing="0">

                <!-- KPI -->
                <HBox spacing="16" style="-fx-padding: 24 35; -fx-background-color: #f1f5f9;">

                    <VBox spacing="12" styleClass="dashboard-stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane styleClass="dashboard-icon-box icon-rose">
                                <Label styleClass="dashboard-icon-label" text="💸" />
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="dashboard-stat-title" text="Total Dépenses" />
                                <Label fx:id="totalDepensesLabel" styleClass="dashboard-stat-value value-rose" text="0 DT" />
                            </VBox>
                        </HBox>
                        <Region maxWidth="1.7976931348623157E308" styleClass="dashboard-stat-bar bar-rose" />
                        <Label styleClass="dashboard-stat-footer footer-rose" text="Engagées" />
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane styleClass="dashboard-icon-box icon-blue">
                                <Label styleClass="dashboard-icon-label" text="📋" />
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="dashboard-stat-title" text="Nombre total" />
                                <Label fx:id="countDepensesLabel" styleClass="dashboard-stat-value dashboard-stat-value-small value-blue" text="0" />
                            </VBox>
                        </HBox>
                        <Region maxWidth="1.7976931348623157E308" styleClass="dashboard-stat-bar bar-blue" />
                        <Label styleClass="dashboard-stat-footer footer-blue" text="Enregistrées" />
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane styleClass="dashboard-icon-box icon-emerald">
                                <Label styleClass="dashboard-icon-label" text="📊" />
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="dashboard-stat-title" text="Ligne moyenne" />
                                <Label fx:id="avgDepenseLabel" styleClass="dashboard-stat-value value-emerald" text="0 DT" />
                            </VBox>
                        </HBox>
                        <Region maxWidth="1.7976931348623157E308" styleClass="dashboard-stat-bar bar-emerald" />
                        <Label styleClass="dashboard-stat-footer footer-emerald" text="Par dépense" />
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-stat-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane styleClass="dashboard-icon-box icon-purple">
                                <Label styleClass="dashboard-icon-label" text="🏷" />
                            </StackPane>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label styleClass="dashboard-stat-title" text="Catégories" />
                                <Label fx:id="categoriesLabel" styleClass="dashboard-stat-value dashboard-stat-value-small value-purple" text="0" />
                            </VBox>
                        </HBox>
                        <Region maxWidth="1.7976931348623157E308" styleClass="dashboard-stat-bar bar-purple" />
                        <Label styleClass="dashboard-stat-footer footer-purple" text="Utilisées" />
                    </VBox>
                </HBox>

                <!-- FILTRES -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 20 35; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

                    <VBox spacing="6">
                        <Label styleClass="filter-label-modern" text="Catégorie" />
                        <ComboBox fx:id="filtreCategorie" prefWidth="220" styleClass="text-field" />
                    </VBox>

                    <VBox spacing="6">
                        <Label styleClass="filter-label-modern" text="Période" />
                        <ComboBox fx:id="filtrePeriode" prefWidth="220" styleClass="text-field" />
                    </VBox>

                    <VBox spacing="6">
                        <Label styleClass="filter-label-modern" text="État financier" />
                        <ComboBox fx:id="filtreEtatFinancier" prefWidth="240" styleClass="text-field" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="exportExcelBtn" minHeight="42" minWidth="170" styleClass="btn-primary" text="📥 Exporter Excel" />

                    <Button fx:id="addBtn" minHeight="42" minWidth="180" styleClass="btn-success" text="➕ Nouvelle Dépense" />
                </HBox>

                <!-- GRAPHE -->
                <VBox style="-fx-padding: 24 35 20 35;">
                    <VBox spacing="12" styleClass="chart-card-modern">
                        <Label styleClass="chart-card-title" text="Répartition des dépenses par catégorie" />
                        <Label styleClass="chart-card-subtitle" text="Visualisation claire des catégories les plus utilisées" />

                        <StackPane maxWidth="1.7976931348623157E308" prefHeight="470" styleClass="chart-image-holder">
                            <PieChart fx:id="categoryPieChart" clockwise="true" labelsVisible="true" legendSide="RIGHT" legendVisible="true" minHeight="430" minWidth="900" prefHeight="430" prefWidth="1000" startAngle="90" styleClass="modern-pie-chart" />
                        </StackPane>
                    </VBox>
                </VBox>

                <!-- LISTE -->
                <VBox spacing="16" styleClass="list-block-modern" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size: 18px;" text="📋" />
                        <Label styleClass="section-title-modern" text="Liste des Dépenses" />
                        <Label fx:id="statusLabel" styleClass="section-desc-modern" text="..." />
                    </HBox>

                    <TilePane fx:id="cardsPane" hgap="16" prefColumns="3" style="-fx-padding: 10;" vgap="16" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
