<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="680.0" prefWidth="600.0"
            style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.questionnaire.ResultatController">
    <children>
        <VBox spacing="18.0"
              AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <!-- TITRE -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 14;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 3);">
                    <children>
                        <Label text="VOS RESULTATS"
                               style="-fx-font-weight: bold; -fx-font-size: 22px; -fx-text-fill: #1e293b;"/>
                        <HBox alignment="CENTER" spacing="20"
                              style="-fx-background-color: #f8fafc; -fx-padding: 14; -fx-background-radius: 10;">
                            <children>
                                <Label fx:id="lblScore" text="Score: 0 / 0"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label fx:id="lblStatus" text="STATUS"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- CORRECTION SCROLLABLE -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: white;
                                   -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10;">
                    <content>
                        <VBox fx:id="vboxCorrection" spacing="12.0"
                              style="-fx-padding: 16; -fx-background-color: white;"/>
                    </content>
                </ScrollPane>

                <!-- CERTIFICAT -->
                <HBox alignment="CENTER">
                    <children>
                        <Button fx:id="btnCertificat" managed="false" onAction="#onDownloadCertificat"
                                text="Telecharger mon certificat"
                                visible="false"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;
                                       -fx-font-size: 14px;"/>
                    </children>
                </HBox>

                <!-- MODIFIER AVIS -->
                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 14;
                             -fx-border-color: #e2e8f0; -fx-border-width: 1.5; -fx-border-radius: 14;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <children>
                        <Label text="Modifier votre avis :"
                               style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 14px;"/>

                        <HBox fx:id="editStarContainer" alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Button text="&#9733;" style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-padding: 0;"/>
                                <Button text="&#9733;" style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-padding: 0;"/>
                                <Button text="&#9733;" style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-padding: 0;"/>
                                <Button text="&#9733;" style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-padding: 0;"/>
                                <Button text="&#9733;" style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-padding: 0;"/>
                            </children>
                        </HBox>

                        <TextArea fx:id="txtAreaComment" prefHeight="70.0"
                                  promptText="Laissez un commentaire..." wrapText="true"
                                  style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-font-size: 13px;"/>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button onAction="#onModifier" text="METTRE A JOUR"
                                        style="-fx-background-color: #10b981; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-padding: 10 20;
                                               -fx-background-radius: 8; -fx-cursor: hand;"/>
                                <Button onAction="#onSupprimer" text="EFFACER MON AVIS"
                                        style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-padding: 10 20;
                                               -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- RETOUR -->
                <Button maxWidth="Infinity" onAction="#retourAccueil"
                        text="RETOUR A L'ACCUEIL"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;"/>

            </children>
        </VBox>
    </children>
</AnchorPane>
