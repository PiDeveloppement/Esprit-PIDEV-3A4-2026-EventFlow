<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0"
      style="-fx-background-color: #f1f5f9; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.questionnaire.QuestionController">

    <children>

        <!-- ===== BREADCRUMB ===== -->
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Button onAction="#switchToList"
                        text="📋 Questions"
                        style="-fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;" />
                <Label text="›" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
                <Label text="Nouvelle question" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
            </children>
        </HBox>

        <!-- ===== PAGE HEADER ===== -->
        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <children>
                <StackPane prefWidth="48.0" prefHeight="48.0"
                           style="-fx-background-color: #dbeafe; -fx-background-radius: 12;">
                    <children>
                        <Label text="+"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;" />
                    </children>
                </StackPane>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Créer une question"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                        <Label text="Ajoutez une nouvelle question à votre questionnaire d'événement."
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b;" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- ===== SCROLLABLE FORM ===== -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: #f1f5f9;">
            <content>
                <VBox spacing="18.0" style="-fx-padding: 2 0;">
                    <children>

                        <!-- ─── SECTION 1 : Question et Reponse ─── -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: linear-gradient(to right, #eff6ff, #dbeafe); -fx-padding: 14 20; -fx-background-radius: 16 16 0 0; -fx-border-color: #bfdbfe; -fx-border-width: 0 0 2 0;">
                                    <children>
                                        <Label text="QUESTION ET REPONSE"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;" />
                                    </children>
                                </HBox>

                                <VBox spacing="18.0" style="-fx-padding: 22 24;">
                                    <children>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="Enonce de la question"
                                                       style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 13px;" />
                                                <HBox spacing="12.0" alignment="TOP_LEFT">
                                                    <children>
                                                        <TextArea fx:id="txtTexte"
                                                                  prefHeight="110.0"
                                                                  promptText="Ex : Quelle est la capitale de la France ?"
                                                                  wrapText="true"
                                                                  HBox.hgrow="ALWAYS"
                                                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" />
                                                        <Button onAction="#genererQuestionParIA"
                                                                text="Generer IA"
                                                                style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="lblSuggestionIA"
                                                       text=""
                                                       style="-fx-font-style: italic; -fx-text-fill: #7c3aed; -fx-font-size: 12px;" />
                                            </children>
                                        </VBox>

                                        <GridPane hgap="20.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="ALWAYS" />
                                                <ColumnConstraints prefWidth="150.0" />
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="8.0" GridPane.columnIndex="0">
                                                    <children>
                                                        <Label text="Reponse correcte"
                                                               style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 13px;" />
                                                        <TextField fx:id="txtReponse"
                                                                   prefHeight="46.0"
                                                                   promptText="Ex : Paris"
                                                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="8.0" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label text="Points"
                                                               style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 13px;" />
                                                        <TextField fx:id="txtPoints"
                                                                   prefHeight="46.0"
                                                                   promptText="0"
                                                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: CENTER;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>

                                    </children>
                                </VBox>

                            </children>
                        </VBox>

                        <!-- ─── SECTION 2 : Options de reponse ─── -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: linear-gradient(to right, #f0fdfa, #ccfbf1); -fx-padding: 14 20; -fx-background-radius: 16 16 0 0; -fx-border-color: #99f6e4; -fx-border-width: 0 0 2 0;">
                                    <children>
                                        <Label text="OPTIONS DE REPONSE"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0f766e;" />
                                    </children>
                                </HBox>

                                <HBox spacing="16.0" style="-fx-padding: 22 24;">
                                    <children>

                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 16;">
                                            <children>
                                                <StackPane prefWidth="30.0" prefHeight="30.0"
                                                           style="-fx-background-color: #3b82f6; -fx-background-radius: 8;">
                                                    <children>
                                                        <Label text="A" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                                    </children>
                                                </StackPane>
                                                <TextField fx:id="txtOption1"
                                                           prefHeight="40.0"
                                                           promptText="Option A..."
                                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 16;">
                                            <children>
                                                <StackPane prefWidth="30.0" prefHeight="30.0"
                                                           style="-fx-background-color: #3b82f6; -fx-background-radius: 8;">
                                                    <children>
                                                        <Label text="B" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                                    </children>
                                                </StackPane>
                                                <TextField fx:id="txtOption2"
                                                           prefHeight="40.0"
                                                           promptText="Option B..."
                                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 16;">
                                            <children>
                                                <StackPane prefWidth="30.0" prefHeight="30.0"
                                                           style="-fx-background-color: #3b82f6; -fx-background-radius: 8;">
                                                    <children>
                                                        <Label text="C" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                                    </children>
                                                </StackPane>
                                                <TextField fx:id="txtOption3"
                                                           prefHeight="40.0"
                                                           promptText="Option C..."
                                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <!-- ─── SECTION 3 : Association ─── -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: linear-gradient(to right, #eef2ff, #e0e7ff); -fx-padding: 14 20; -fx-background-radius: 16 16 0 0; -fx-border-color: #c7d2fe; -fx-border-width: 0 0 2 0;">
                                    <children>
                                        <Label text="ASSOCIATION"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4338ca;" />
                                    </children>
                                </HBox>

                                <VBox spacing="8.0" style="-fx-padding: 22 24;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label text="Evenement associe"
                                                       style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 13px;" />
                                                <Label text="(optionnel)"
                                                       style="-fx-font-size: 11px; -fx-text-fill: #ef4444;" />
                                            </children>
                                        </HBox>
                                        <ComboBox fx:id="comboEvent"
                                                  maxWidth="Infinity"
                                                  prefHeight="46.0"
                                                  promptText="Choisir un evenement"
                                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <!-- ===== FOOTER ACTIONS ===== -->
        <HBox alignment="CENTER_RIGHT" spacing="14.0" style="-fx-padding: 8 0 0 0;">
            <children>
                <Button onAction="#switchToList"
                        text="Retour"
                        prefHeight="46.0" prefWidth="130.0"
                        style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-cursor: hand;" />
                <Button onAction="#handleSave"
                        text="Enregistrer la question"
                        prefHeight="46.0"
                        style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-padding: 0 28; -fx-cursor: hand;" />
            </children>
        </HBox>

    </children>
</VBox>
