<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.questionnaire.ParticipantController"
      prefWidth="1100" prefHeight="720"
      fillHeight="true"
      style="-fx-background-color: #f0f4f8;">

    <VBox HBox.hgrow="ALWAYS" spacing="0" fillWidth="true">

        <!-- HEADER VIOLET -->
        <VBox style="-fx-background-color: linear-gradient(to bottom right, #4f46e5, #7c3aed); -fx-padding: 28 40 28 40;">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="Session de Quiz"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" HBox.hgrow="ALWAYS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblNumQuestion" text="Question 1/10"
                               style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white;
                                      -fx-font-weight: bold; -fx-font-size: 13px;
                                      -fx-padding: 6 16; -fx-background-radius: 20;"/>
                    </children>
                </HBox>

                <ProgressBar fx:id="pgBar" maxWidth="Infinity" prefHeight="10" progress="0.0"
                             style="-fx-accent: #f59e0b; -fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 10;">
                    <VBox.margin><Insets top="14" bottom="14"/></VBox.margin>
                </ProgressBar>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <Label fx:id="lblProgression" text="0%"
                               style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                                      -fx-font-weight: bold; -fx-font-size: 13px;
                                      -fx-padding: 5 14; -fx-background-radius: 20;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="En attente de confirmation..."
                               style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- CONTENU SCROLLABLE -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 30 40 20 40; -fx-background-color: #f0f4f8;">
                    <children>

                        <!-- CARTE QUESTION + OPTIONS -->
                        <VBox spacing="16"
                              style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 14;
                                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                            <children>
                                <Label fx:id="lblQuestion" text="Chargement de la question..."
                                       wrapText="true"
                                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Separator style="-fx-opacity: 0.4;"/>
                                <VBox fx:id="vboxOptions" spacing="12" style="-fx-padding: 6 0 0 0;"/>
                            </children>
                        </VBox>

                        <!-- CARTE EVALUATION -->
                        <VBox fx:id="vboxEvaluation" spacing="16" visible="false" managed="false"
                              style="-fx-background-color: #fffbeb; -fx-padding: 28; -fx-background-radius: 14;
                                     -fx-border-color: #fde68a; -fx-border-width: 2; -fx-border-radius: 14;">
                            <children>

                                <HBox alignment="CENTER" spacing="10">
                                    <children>
                                        <Label text="Quiz termine !"
                                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>
                                    </children>
                                </HBox>

                                <Label text="Evaluez votre experience"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>

                                <Label text="Note (0-5 etoiles)"
                                       style="-fx-font-size: 12px; -fx-text-fill: #78716c;"/>

                                <HBox fx:id="starContainer" spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="&#9733;" style="-fx-background-color: #fef3c7; -fx-text-fill: #f59e0b; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 4 8; -fx-background-radius: 50; -fx-border-color: #fde68a; -fx-border-radius: 50;"/>
                                        <Button text="&#9733;" style="-fx-background-color: #fef3c7; -fx-text-fill: #f59e0b; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 4 8; -fx-background-radius: 50; -fx-border-color: #fde68a; -fx-border-radius: 50;"/>
                                        <Button text="&#9733;" style="-fx-background-color: #fef3c7; -fx-text-fill: #f59e0b; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 4 8; -fx-background-radius: 50; -fx-border-color: #fde68a; -fx-border-radius: 50;"/>
                                        <Button text="&#9733;" style="-fx-background-color: #fef3c7; -fx-text-fill: #f59e0b; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 4 8; -fx-background-radius: 50; -fx-border-color: #fde68a; -fx-border-radius: 50;"/>
                                        <Button text="&#9733;" style="-fx-background-color: #fef3c7; -fx-text-fill: #f59e0b; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 4 8; -fx-background-radius: 50; -fx-border-color: #fde68a; -fx-border-radius: 50;"/>
                                    </children>
                                </HBox>

                                <Label text="Votre commentaire"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>

                                <TextArea fx:id="txtCommentaire"
                                          promptText="Partagez votre avis sur ce quiz..."
                                          prefHeight="100" wrapText="true"
                                          style="-fx-background-radius: 8; -fx-border-color: #fde68a; -fx-border-radius: 8; -fx-font-size: 14px;"/>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="Emoji" onAction="#toggleEmojiPicker"
                                                style="-fx-background-color: white; -fx-font-size: 13; -fx-cursor: hand;
                                                       -fx-background-radius: 8; -fx-padding: 4 10;
                                                       -fx-border-color: #fde68a; -fx-border-radius: 8;"/>
                                    </children>
                                </HBox>

                                <FlowPane fx:id="emojiPicker" visible="false" managed="false" hgap="8" vgap="8"
                                          style="-fx-background-color: white; -fx-padding: 10;
                                                 -fx-background-radius: 10; -fx-border-color: #fde68a; -fx-border-radius: 10;"/>
                            </children>
                        </VBox>

                        <TextField fx:id="txtReponseParticipant" visible="false" managed="false"/>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <!-- FOOTER -->
        <HBox alignment="CENTER_RIGHT" spacing="16"
              style="-fx-background-color: white; -fx-padding: 18 40;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 8, 0, -3, 0);">
            <children>
                <Button text="Precedent"
                        style="-fx-background-color: white; -fx-text-fill: #4f46e5; -fx-font-weight: bold;
                               -fx-font-size: 14px; -fx-padding: 12 30; -fx-background-radius: 8;
                               -fx-border-color: #4f46e5; -fx-border-radius: 8; -fx-cursor: hand;"/>
                <Button fx:id="btnSuivant" onAction="#handleSuivant" text="Suivant"
                        style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-font-size: 14px; -fx-padding: 12 36; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </children>
        </HBox>
    </VBox>

    <!-- SIDEBAR DROITE -->
    <VBox prefWidth="240" minWidth="240" maxWidth="240" HBox.hgrow="NEVER"
          style="-fx-background-color: white; -fx-padding: 28 20;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 12, -3, 0, 0);">
        <children>

            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 12;
                         -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-border-width: 1.5;">
                <children>
                    <Label fx:id="lblScoreSide" text="0%"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label fx:id="lblScoreDetail" text="0 reponse(s) correcte(s)"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;" wrapText="true"/>
                </children>
            </VBox>

            <Separator>
                <VBox.margin><Insets top="14" bottom="10"/></VBox.margin>
            </Separator>

            <Label text="Questions"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 0 0 6 0;"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="sidebarQuestionsVBox" spacing="8" style="-fx-padding: 2;"/>
                </content>
            </ScrollPane>

        </children>
    </VBox>

</HBox>
