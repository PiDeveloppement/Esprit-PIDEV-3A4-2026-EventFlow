<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.event.EventTicketViewController"
      spacing="0" style="-fx-background-color: #f8fafc;" VBox.vgrow="ALWAYS">

    <!-- ============ HEADER (fixe, hors ScrollPane) ============ -->
    <HBox style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="15">

        <Button fx:id="backBtn" text="← Retour aux billets"
                styleClass="btn-secondary" onAction="#handleBack"
                style="-fx-padding: 10 20; -fx-font-size: 14px;"/>

        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Détails du Billet"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Consultation et gestion du billet d'événement"
                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="downloadBtn" text="📄 PDF"
                styleClass="btn-outline" onAction="#handleDownloadPDF"
                style="-fx-padding: 10 20; -fx-font-size: 13px;"/>
    </HBox>

    <!-- ============ SCROLLPANE (prend tout le reste) ============ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                maxHeight="1.7976931348623157E308"
                style="-fx-background-color: #f8fafc; -fx-border-color: transparent; -fx-background: #f8fafc;">

        <!-- ============ CONTENT (2 COLUMNS) ============ -->
        <HBox spacing="30" style="-fx-padding: 30; -fx-background-color: #f8fafc;">

            <!-- LEFT: QR CODE -->
            <VBox spacing="15" alignment="TOP_CENTER" style="-fx-min-width: 350;">
                <Label text="Code de Vérification"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                <StackPane fx:id="qrCodeContainer"
                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 20;"
                           alignment="CENTER">
                    <ImageView fx:id="qrCodeImage" fitHeight="280" fitWidth="280"
                               preserveRatio="true"/>
                </StackPane>

                <VBox spacing="5" style="-fx-padding: 15; -fx-background-color: white; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                    <Label text="Numéro du Billet"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <Label fx:id="ticketCodeLabel" text="EVT-XX-XX-XXXXXX"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1565C0; -fx-font-family: monospace;"/>
                </VBox>
            </VBox>

            <!-- RIGHT: DETAILS -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <Label fx:id="statusBadge" text="✅ Ticket Valide"
                       style="-fx-background-color: #dcfce7; -fx-text-fill: #166534; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 16; -fx-background-radius: 20;"/>

                <!-- EVENT INFO -->
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: white; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                    <Label text="Événement"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="📅" style="-fx-font-size: 16px;"/>
                        <VBox spacing="2">
                            <Label fx:id="eventNameLabel" text="Événement"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <Label fx:id="eventDateLabel" text="Date"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="📍" style="-fx-font-size: 16px;"/>
                        <Label fx:id="eventLocationLabel" text="Lieu"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                    </HBox>
                </VBox>

                <!-- PARTICIPANT INFO -->
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: white; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                    <Label text="Participant"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="👤" style="-fx-font-size: 16px;"/>
                        <VBox spacing="2">
                            <Label fx:id="participantNameLabel" text="Nom du participant"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <Label fx:id="participantEmailLabel" text="email@example.com"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- DATES -->
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: white; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                    <Label text="Dates"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="20">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Créé le" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="createdAtLabel" text="01/01/2026 10:30"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Utilisé le" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="updatedAtLabel" text="Non utilisé"
                                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </ScrollPane>

</VBox>
